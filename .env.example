# === Front (browser) — solo claves públicas, prefijo VITE_ ===
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Base path del router (prod usa /doc; dev puede usar /). Opcional.
VITE_BASE_PATH=/

# === Secrets de Edge Functions — NO usan prefijo VITE_, viven en Supabase ===
# (se setean con: supabase secrets set NOMBRE=valor)
#   SSO_GESTA_OS_HUB_URL
#   SSO_GESTA_OS_APP_SLUG
#   SSO_GESTA_OS_AUDIENCE
#   DOCNOMINA_INTERNAL_API_KEY
#   RESEND_API_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#
# ⚠️ Regla de oro: el service_role key NUNCA va en el front (VITE_*).
# El front usa solo anon key + sesión del usuario; la autoridad la da RLS.
