# Secrets para `supabase functions serve --env-file supabase/functions/.env.local`
# y para `supabase secrets set ...` en el proyecto remoto.
#
# NOTA: SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY los inyecta la plataforma
# automáticamente (no se setean como secrets en deploy). En local serve también
# se proveen solos; solo necesitas declararlos si corres fuera del stack local.

# --- SSO Gesta OS ---
SSO_GESTA_OS_HUB_URL=https://<hub-ref>.supabase.co
SSO_GESTA_OS_APP_SLUG=docnomina
SSO_GESTA_OS_AUDIENCE=docnomina.com

# --- Integración server-to-server ---
# Debe ser IGUAL al DOCNOMINA_SSO_API_KEY del lado Gesta OS.
DOCNOMINA_INTERNAL_API_KEY=
